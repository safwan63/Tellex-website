# Admin Password (REQUIRED FOR SECURITY)
# Set a strong password for accessing the /admin page
# Use a password manager to generate a secure password
# Example: VITE_ADMIN_PASSWORD=your-very-secure-password-here
VITE_ADMIN_PASSWORD=change-this-to-a-strong-password
